# ADAM API Configuration
# ========================================

# Your ADAM API token (30 characters)
# Get this from: Administration → Security Administration → Manage API Tokens
ADAM_API_TOKEN=your_30_character_token_here

# Full URL to your ADAM API endpoint (including /api)
# Examples:
#   - https://yourschool.adam.co.za/api
#   - https://adam.yourschool.edu/api
#   - https://sis.yourschool.com/api
ADAM_BASE_URL=https://yourschool.adam.co.za/api

# SSL certificate verification (true/false)
# Set to "false" for development with self-signed certificates
# ALWAYS use "true" in production with proper SSL certificates
ADAM_VERIFY_SSL=true

# MCP Server Configuration
# ========================================

# Name displayed to MCP clients
MCP_SERVER_NAME=ADAM School MIS

# Host and port for the MCP server
# 127.0.0.1 = localhost only (recommended for dev and production with reverse proxy)
# 0.0.0.0 = all network interfaces (allows access from other machines, less secure)
MCP_HOST=127.0.0.1
MCP_PORT=8000
